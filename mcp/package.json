{
  "name": "@maker-express/mcp-server",
  "version": "0.2.0",
  "description": "MCP server for the Maker Express and Hardstack hardware ecosystem directory",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "maker-express-mcp": "./dist/index.js",
    "hardstack-mcp": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node scripts/copy-data.mjs",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "smoke": "node scripts/smoke.mjs",
    "smoke:prod": "HARDWARE_DIRECTORY_API_URL=https://api.maker.express node scripts/smoke.mjs --call",
    "smoke:auth-fallback": "node scripts/auth-fallback-smoke.mjs"
  },
  "keywords": [
    "mcp",
    "maker-express",
    "hardstack",
    "hardware",
    "makers",
    "directory",
    "skills"
  ],
  "author": "Maker Express Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Maker-Express/Maker-Express.git",
    "directory": "mcp"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.24.5"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
